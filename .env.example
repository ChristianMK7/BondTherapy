# Copy to .env and fill in real values
PORT=3000
SESSION_SECRET=replace-this-with-a-long-random-string

# Admin credentials — used to log into /admin
ADMIN_USER=admin
ADMIN_PASS=change-me-to-something-strong

# Set in production once you deploy with HTTPS
# NODE_ENV=production
# PUBLIC_URL=https://yourdomain.com

# Payment methods — shown to clients when paying for a booking
WHISH_NUMBER=+961 XX XXX XXX
WHISH_NAME=Your Name
OMT_NUMBER=+961 XX XXX XXX
OMT_NAME=Your Name

# Email (optional — for booking/signup notifications). Get a free key from https://resend.com
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=notifications@yourdomain.com
# EMAIL_ADMIN=you@gmail.com
